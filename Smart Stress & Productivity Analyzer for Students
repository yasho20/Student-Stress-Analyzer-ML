import pandas as pd
import numpy as np
# Set random seed for reproducibility
np.random.seed(42)

# Number of students
num_students = 20

# Create synthetic dataset
data = {
    "Student_ID": [f"S{i+1:02d}" for i in range(num_students)],
    "Attendance (%)": np.random.randint(50, 95, num_students),
    "Study_Hours": np.round(np.random.uniform(1, 5, num_students), 1),
    "Sleep_Hours": np.round(np.random.uniform(4, 8, num_students), 1),
    "Screen_Time": np.round(np.random.uniform(2, 8, num_students), 1),
    "Stress_Score": np.random.randint(1, 6, num_students)
}
 
df = pd.DataFrame(data)

print("Synthetic Student Dataset:\n")
print(df)
def categorize_stress(score):
    if score >= 4:
        return "High"
    elif score == 3:
        return "Medium"
    else:
        return "Low"

def categorize_attendance(att):
    if att < 65:
        return "Low"
    elif att <= 80:
        return "Moderate"
    else:
        return "High"

df["Stress_Level"] = df["Stress_Score"].apply(categorize_stress)
df["Attendance_Level"] = df["Attendance (%)"].apply(categorize_attendance)
def recommend_plan(stress, attendance):
    if stress == "High" and attendance == "Low":
        return "Class: 3–4 hrs | Study: 1.5–2 hrs | Stress recovery & core subjects"

    elif stress == "Medium" and attendance == "Low":
        return "Class: 4–5 hrs | Study: 2–3 hrs | Gradual improvement"

    elif stress == "High" and attendance == "High":
        return "Class: 4 hrs | Study: 2 hrs | Burnout prevention"

    else:
        return "Class: 5 hrs | Study: 3 hrs | Maintain balance"

df["Recommendation"] = df.apply(
    lambda row: recommend_plan(row["Stress_Level"], row["Attendance_Level"]),
    axis=1
)
print("\nFinal Stress & Productivity Analysis with Recommendations:\n")
print(df[[
    "Student_ID",
    "Attendance (%)",
    "Stress_Level",
    "Attendance_Level",
    "Recommendation"
]])






           
