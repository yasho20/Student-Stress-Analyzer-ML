import pandas as pd
import numpy as np
# Set random seed for reproducibility
np.random.seed(42)

# Number of students
num_students = 20

# Create synthetic dataset
data = {
    "Student_ID": [f"S{i+1:02d}" for i in range(num_students)],
    "Attendance (%)": np.random.randint(50, 95, num_students),
    "Study_Hours": np.round(np.random.uniform(1, 5, num_students), 1),
    "Sleep_Hours": np.round(np.random.uniform(4, 8, num_students), 1),
    "Screen_Time": np.round(np.random.uniform(2, 8, num_students), 1),
    "Stress_Score": np.random.randint(1, 6, num_students)
}
 
df = pd.DataFrame(data)

print("Synthetic Student Dataset:\n")
print(df)
def categorize_stress(score):
    if score >= 4:
        return "High"
    elif score == 3:
        return "Medium"
    else:
        return "Low"

def categorize_attendance(att):
    if att < 65:
        return "Low"
    elif att <= 80:
        return "Moderate"
    else:
        return "High"

df["Stress_Level"] = df["Stress_Score"].apply(categorize_stress)
df["Attendance_Level"] = df["Attendance (%)"].apply(categorize_attendance)
def recommend_plan(stress, attendance):
    if stress == "High" and attendance == "Low":
        return "Class: 3–4 hrs | Study: 1.5–2 hrs | Stress recovery & core subjects"

    elif stress == "Medium" and attendance == "Low":
        return "Class: 4–5 hrs | Study: 2–3 hrs | Gradual improvement"

    elif stress == "High" and attendance == "High":
        return "Class: 4 hrs | Study: 2 hrs | Burnout prevention"

    else:
        return "Class: 5 hrs | Study: 3 hrs | Maintain balance"

df["Recommendation"] = df.apply(
    lambda row: recommend_plan(row["Stress_Level"], row["Attendance_Level"]),
    axis=1
)
print("\nFinal Stress & Productivity Analysis with Recommendations:\n")
print(df[[
    "Student_ID",
    "Attendance (%)",
    "Stress_Level",
    "Attendance_Level",
    "Recommendation"
]])




import pandas as pd
import numpy as np  

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import accuracy_score, classification_report
np.random.seed(42)
num_students = 50

data = {
    "Attendance": np.random.randint(50, 95, num_students),
    "Study_Hours": np.round(np.random.uniform(1, 5, num_students), 1),
    "Sleep_Hours": np.round(np.random.uniform(4, 8, num_students), 1),
    "Screen_Time": np.round(np.random.uniform(2, 8, num_students), 1),
    "Stress_Score": np.random.randint(1, 6, num_students)
}

df = pd.DataFrame(data)
def stress_label(score):
    if score >= 4:
        return "High"
    elif score == 3:
        return "Medium"
    else:
        return "Low"

df["Stress_Level"] = df["Stress_Score"].apply(stress_label)
le = LabelEncoder()
df["Stress_Encoded"] = le.fit_transform(df["Stress_Level"])
X = df[["Attendance", "Study_Hours", "Sleep_Hours", "Screen_Time"]]
y = df["Stress_Encoded"]
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.25, random_state=42
)
model = LogisticRegression(max_iter=1000)
model.fit(X_train, y_train)
y_pred = model.predict(X_test)

print("Model Accuracy:", accuracy_score(y_test, y_pred))
print("\nClassification Report:\n", classification_report(y_test, y_pred))
# Example new student
new_student = pd.DataFrame({
    "Attendance": [60],
    "Study_Hours": [2.0],
    "Sleep_Hours": [5.0],
    "Screen_Time": [6.5]
})

predicted_class = model.predict(new_student)
predicted_stress = le.inverse_transform(predicted_class)

print("Predicted Stress Level:", predicted_stress[0])
def recommend_plan_ml(stress, attendance):
    if stress == "High" and attendance < 65:
        return "Class: 3–4 hrs | Study: 1.5–2 hrs | Stress recovery"

    elif stress == "Medium" and attendance < 65:
        return "Class: 4–5 hrs | Study: 2–3 hrs | Gradual improvement"

    elif stress == "High" and attendance >= 80:
        return "Class: 4 hrs | Study: 2 hrs | Burnout prevention"

    else:
        return "Class: 5 hrs | Study: 3 hrs | Maintain balance"

final_recommendation = recommend_plan_ml(
    predicted_stress[0],
    new_student["Attendance"].values[0]
)

print("Personalized Recommendation:")
print(final_recommendation)
           